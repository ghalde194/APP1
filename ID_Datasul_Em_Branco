      "source": [
        "from google.colab import files\n",
        "import pandas as pd\n",
        "from datetime import datetime\n",
        "\n",
        "# === Constantes do Programa ===\n",
        "WORKDAY_SHEET_KEYWORD = 'workday'\n",
        "ID_DATASUL_COLUMN = 'ID DATASUL'\n",
        "NAME_COLUMN_WORKDAY = 'Legal Name in General Display Format'\n",
        "OUTPUT_FILE_PREFIX = 'IDS_DATASUL_EM_BRANCO_Workday_Kion_Dematic'\n",
        "OUTPUT_SHEET_NAME_BLANK = 'IDs Datasul em Branco'\n",
        "OUTPUT_SHEET_NAME_FULL = 'Completo - Workday'\n",
        "\n",
        "print(\"🚀 PROGRAMA - IDs Datasul em Branco no Workday (Kion e Dematic)\")\n",
        "print(\"=\" * 85)\n",
        "\n",
        "def process_workday_data(file_path):\n",
        "    # === Diagnóstico automático das abas ===\n",
        "    xls = pd.ExcelFile(file_path)\n",
        "    print(\"\\n📋 ABAS ENCONTRADAS NO ARQUIVO:\")\n",
        "    for i, aba in enumerate(xls.sheet_names, 1):\n",
        "        print(f\"{i}. '{aba}'\")\n",
        "\n",
        "    # Busca automática pela aba Workday (mais flexível)\n",
        "    aba_workday = None\n",
        "    for aba in xls.sheet_names:\n",
        "        if WORKDAY_SHEET_KEYWORD in aba.lower():\n",
        "            aba_workday = aba\n",
        "            break\n",
        "\n",
        "    if not aba_workday:\n",
        "        print(\"\\n❌ Não encontrei nenhuma aba com 'Workday' no nome.\")\n",
        "        print(\"Verifique as abas acima e me avise o nome exato.\")\n",
        "        raise Exception(\"Aba Workday não encontrada\")\n",
        "\n",
        "    print(f\"\\n✅ Usando aba: '{aba_workday}'\")\n",
        "\n",
        "    # === Leitura da aba Workday ===\n",
        "    df_workday = pd.read_excel(file_path, sheet_name=aba_workday)\n",
        "\n",
        "    print(f\"✅ Workday carregada com sucesso: {len(df_workday)} linhas\")\n",
        "\n",
        "    # === Buscar IDs Datasul em branco no Workday ===\n",
        "    # Considera como em branco: NaN, None, string vazia ou apenas espaços\n",
        "    df_blank = df_workday[\n",
        "        df_workday[ID_DATASUL_COLUMN].isna() |\n",
        "        (df_workday[ID_DATASUL_COLUMN].astype(str).str.strip() == '')\n",
        "    ].copy()\n",
        "\n",
        "    print(f\"\\n🔍 Encontrados **{len(df_blank)}** funcionários com '{ID_DATASUL_COLUMN}' em branco no Workday\")\n",
        "\n",
        "    # === Ordenar por Nome (se a coluna existir) ===\n",
        "    if NAME_COLUMN_WORKDAY in df_blank.columns:\n",
        "        df_blank = df_blank.sort_values(by=NAME_COLUMN_WORKDAY)\n",
        "\n",
        "    # === Colunas mais úteis para mostrar ===\n",
        "    colunas_exibir = [\n",
        "        \"ID\",\n",
        "        \"ID WORKDAY\",\n",
        "        ID_DATASUL_COLUMN,\n",
        "        NAME_COLUMN_WORKDAY,\n",
        "        \"Employee ID\",\n",
        "        \"Job Profile (Primary)\",\n",
        "        \"Contingent Worker\",\n",
        "        \"Hire Date\",\n",
        "        \"End Employment Date\"\n",
        "    ]\n",
        "\n",
        "    # Filtra apenas as colunas que realmente existem\n",
        "    colunas_exibir = [c for c in colunas_exibir if c in df_blank.columns]\n",
        "\n",
        "    df_resultado = df_blank[colunas_exibir].copy()\n",
        "\n",
        "    # === Gerar arquivo de saída ===\n",
        "    timestamp = datetime.now().strftime('%Y%m%d_%H%M')\n",
        "    nome_saida = f\"{OUTPUT_FILE_PREFIX}_{timestamp}.xlsx\"\n",
        "\n",
        "    with pd.ExcelWriter(nome_saida, engine=\"openpyxl\") as writer:\n",
        "        df_resultado.to_excel(writer, sheet_name=OUTPUT_SHEET_NAME_BLANK, index=False)\n",
        "\n",
        "        # Salva também a aba completa para referência\n",
        "        df_workday.to_excel(writer, sheet_name=OUTPUT_SHEET_NAME_FULL, index=False)\n",
        "\n",
        "        # Formatação automática das colunas (igual aos seus códigos)\n",
        "        for sheet_name in writer.sheets:\n",
        "            ws = writer.sheets[sheet_name]\n",
        "            for col in ws.columns:\n",
        "                max_length = 0\n",
        "                column_letter = col[0].column_letter\n",
        "                for cell in col:\n",
        "                    try:\n",
        "                        if len(str(cell.value)) > max_length:\n",
        "                            max_length = len(str(cell.value))\n",
        "                    except:\n",
        "                        pass\n",
        "                ws.column_dimensions[column_letter].width = min(max_length + 3, 50)\n",
        "            ws.freeze_panes = \"A2\"\n",
        "\n",
        "    print(\"\\n\" + \"=\"*80)\n",
        "    print(\"RESULTADO FINAL\")\n",
        "    print(\"=\"*80)\n",
        "    print(f\"Total de registros no Workday          : {len(df_workday)}\")\n",
        "    print(f\"Funcionários com '{ID_DATASUL_COLUMN}' em branco: {len(df_resultado)}\")\n",
        "\n",
        "    if len(df_resultado) > 0:\n",
        "        print(f\"\\n⚠️  Foram encontrados {len(df_resultado)} funcionários sem '{ID_DATASUL_COLUMN}' no Workday.\")\n",
        "    else:\n",
        "        print(f\"\\n✅ Parabéns! Nenhuma matrícula '{ID_DATASUL_COLUMN}' em branco encontrada no Workday.\")\n",
        "\n",
        "    print(f\"\\n✅ Arquivo gerado: {nome_saida}\")\n",
        "    files.download(nome_saida)\n",
        "\n",
        "# === Upload do arquivo e chamada da função ===\n",
        "uploaded = files.upload()\n",
        "nome_arquivo = next(iter(uploaded))\n",
        "process_workday_data(nome_arquivo)"
      ],
