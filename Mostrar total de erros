      },
      "source": [
        "# Extrair nomes do Datasul e Workday\n",
        "nomes_datasul = df_datasul['Nome'].apply(padronizar_texto)\n",
        "nomes_workday = df_workday['Legal Name in General Display Format'].apply(padronizar_texto)\n",
        "\n",
        "# Combinar todos os nomes em uma única série\n",
        "todos_nomes = pd.concat([nomes_datasul, nomes_workday], ignore_index=True)\n",
        "\n",
        "# Remover nomes vazios ou nulos que possam ter resultado da padronização\n",
        "todos_nomes = todos_nomes[todos_nomes != ''].reset_index(drop=True)\n",
        "\n",
        "# Obter nomes únicos\n",
        "nomes_unicos = todos_nomes.drop_duplicates().sort_values().reset_index(drop=True)\n",
        "\n",
        "print(f\"Total de nomes únicos encontrados em ambos os sistemas: {len(nomes_unicos)}\")\n",
        "display(nomes_unicos.head(20)) # Exibir os primeiros 20 nomes únicos"
      ],
