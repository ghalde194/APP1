      "source": [
        "import unicodedata\n",
        "from google.colab import files\n",
        "import pandas as pd\n",
        "from openpyxl.styles import Alignment, Border, Font, PatternFill, Side\n",
        "from openpyxl.utils import get_column_letter\n",
        "\n",
        "\n",
        "# Função para limpar e padronizar os textos\n",
        "def padronizar_texto(texto):\n",
        "    if pd.isna(texto):\n",
        "        return \"\"\n",
        "    texto = str(texto).strip().upper()\n",
        "    texto = (\n",
        "        unicodedata.normalize(\"NFKD\", texto)\n",
        "        .encode(\"ascii\", \"ignore\")\n",
        "        .decode(\"utf-8\")\n",
        "    )\n",
        "    return \" \".join(texto.split())\n",
        "\n",
        "\n",
        "# Função para garantir que as matrículas alinhem perfeitamente\n",
        "def padronizar_matricula(valor):\n",
        "    if pd.isna(valor):\n",
        "        return \"\"\n",
        "    try:\n",
        "        return str(int(float(valor))).strip()\n",
        "    except ValueError:\n",
        "        return str(valor).strip()\n",
        "\n",
        "\n",
        "# 1. PASSO: Selecionar o arquivo\n",
        "print(\"Por favor, selecione o arquivo Excel com as duas abas...\")\n",
        "uploaded = files.upload()\n",
        "nome_arquivo_origem = list(uploaded.keys())[0]\n",
        "\n",
        "# 2. PASSO: Carregar os dados\n",
        "print(\"\\nLendo as abas do arquivo...\")\n",
        "xls = pd.ExcelFile(nome_arquivo_origem)\n",
        "sheet_names = xls.sheet_names\n",
        "\n",
        "datasul_sheet_name = next(\n",
        "    (s for s in sheet_names if \"datasul\" in s.strip().lower()), None\n",
        ")\n",
        "workday_sheet_name = next(\n",
        "    (s for s in sheet_names if \"workday\" in s.strip().lower()), None\n",
        ")\n",
        "\n",
        "df_datasul = pd.read_excel(nome_arquivo_origem, sheet_name=datasul_sheet_name)\n",
        "df_workday = pd.read_excel(nome_arquivo_origem, sheet_name=workday_sheet_name)\n",
        "\n",
        "# Ajustando as matrículas\n",
        "df_datasul[\"Matrícula\"] = df_datasul[\"Matrícula\"].apply(padronizar_matricula)\n",
        "df_workday[\"ID DATASUL\"] = df_workday[\"ID DATASUL\"].apply(padronizar_matricula)\n",
        "\n",
        "# 3. PASSO: Selecionando apenas as colunas de origem necessárias\n",
        "df_datasul_filtrado = df_datasul[\n",
        "    [\"Matrícula\", \"Nome\", \"Cargo Básico-Descrição\"]\n",
        "].copy()\n",
        "df_workday_filtrado = df_workday[\n",
        "    [\n",
        "        \"ID DATASUL\",\n",
        "        \"Legal Name in General Display Format\",\n",
        "        \"Business Title\",\n",
        "    ]\n",
        "].copy()\n",
        "\n",
        "# Rename para possibilitar o merge\n",
        "df_workday_filtrado.rename(columns={\"ID DATASUL\": \"Matrícula\"}, inplace=True)\n",
        "\n",
        "# 4. PASSO: Criando colunas auxiliares para comparação justa\n",
        "df_datasul_filtrado[\"_cargo_comp\"] = df_datasul_filtrado[\n",
        "    \"Cargo Básico-Descrição\"\n",
        "].apply(padronizar_texto)\n",
        "df_workday_filtrado[\"_cargo_comp\"] = df_workday_filtrado[\n",
        "    \"Business Title\"\n",
        "].apply(padronizar_texto)\n",
        "\n",
        "# 5. PASSO: Cruzando os dados (Inner Merge para focar em quem existe nos dois)\n",
        "print(\"Cruzando e comparando os dados...\")\n",
        "df_comparacao = pd.merge(\n",
        "    df_datasul_filtrado,\n",
        "    df_workday_filtrado,\n",
        "    on=\"Matrícula\",\n",
        "    how=\"inner\",\n",
        "    suffixes=(\"_DS\", \"_WD\"),\n",
        ")\n",
        "\n",
        "# 6. PASSO: Validando as divergências de cargo\n",
        "df_comparacao[\"Status do Cargo\"] = df_comparacao.apply(\n",
        "    lambda row: \"Correto ✅\"\n",
        "    if row[\"_cargo_comp_DS\"] == row[\"_cargo_comp_WD\"]\n",
        "    else \"Erro ❌\",\n",
        "    axis=1,\n",
        ")\n",
        "\n",
        "# 7. PASSO: Organizando as colunas finais\n",
        "colunas_finais = [\n",
        "    \"Matrícula\",\n",
        "    \"Nome\",\n",
        "    \"Legal Name in General Display Format\",  # Use actual column name from df_workday_filtrado\n",
        "    \"Cargo Básico-Descrição\",  # Use actual column name from df_datasul_filtrado\n",
        "    \"Business Title\",  # Use actual column name from df_workday_filtrado\n",
        "    \"Status do Cargo\",\n",
        "]\n",
        "\n",
        "df_base_completa = df_comparacao[colunas_finais].copy()\n",
        "\n",
        "# Renomeando as colunas para o padrão visual\n",
        "df_base_completa.columns = [\n",
        "    \"Matrícula\",\n",
        "    \"Nome\",\n",
        "    \"Nome (Workday)\",\n",
        "    \"Cargo (Datasul)\",\n",
        "    \"Cargo (Workday)\",\n",
        "    \"Status do Cargo\",\n",
        "]\n",
        "\n",
        "# --- FILTRO CRÍTICO: DEIXA APENAS O QUE FOR ERRO ---\n",
        "df_apenas_erros = df_base_completa[\n",
        "    df_base_completa[\"Status do Cargo\"] == \"Erro ❌\"\n",
        "].copy()\n",
        "\n",
        "# === PASSO 7.5: ORDENANDO POR ORDEM ALFABÉTICA ===\n",
        "# O parâmetro 'ascending=True' garante a ordem de A a Z\n",
        "df_apenas_erros = df_apenas_erros.sort_values(by=\"Nome\", ascending=True)\n",
        "\n",
        "\n",
        "# 8. PASSO: Salvando no Excel e formatando a saída\n",
        "nome_arquivo_saida = \"Relatorio_Erros_Encontrados.xlsx\"\n",
        "\n",
        "\n",
        "def formatar_aba(ws, df):\n",
        "    # Cores\n",
        "    header_fill = PatternFill(\n",
        "        start_color=\"1F497D\", end_color=\"1F497D\", fill_type=\"solid\"\n",
        "    )  # Azul Escuro\n",
        "    error_fill = PatternFill(\n",
        "        start_color=\"FFC7CE\", end_color=\"FFC7CE\", fill_type=\"solid\"\n",
        "    )  # Vermelho Claro\n",
        "\n",
        "    thin_border = Border(\n",
        "        left=Side(style=\"thin\", color=\"D3D3D3\"),\n",
        "        right=Side(style=\"thin\", color=\"D3D3D3\"),\n",
        "        top=Side(style=\"thin\", color=\"D3D3D3\"),\n",
        "        bottom=Side(style=\"thin\", color=\"D3D3D3\"),\n",
        "    )\n",
        "\n",
        "    # Formatar Cabeçalho\n",
        "    for col_num, header in enumerate(df.columns, 1):\n",
        "        cell = ws.cell(row=1, column=col_num)\n",
        "        cell.font = Font(color=\"FFFFFF\", bold=True, name=\"Calibri\", size=11)\n",
        "        cell.fill = header_fill\n",
        "        cell.alignment = Alignment(horizontal=\"center\", vertical=\"center\")\n",
        "        cell.border = thin_border\n",
        "\n",
        "    # Formatar Linhas de Dados\n",
        "    for row in range(2, ws.max_row + 1):\n",
        "        for col in range(1, ws.max_column + 1):\n",
        "            cell = ws.cell(row=row, column=col)\n",
        "            cell.border = thin_border\n",
        "            cell.font = Font(name=\"Calibri\", size=11)\n",
        "            cell.alignment = Alignment(vertical=\"center\")\n",
        "\n",
        "            # Centralizar matrícula e status\n",
        "            if col in [1, 6]:\n",
        "                cell.alignment = Alignment(\n",
        "                    horizontal=\"center\", vertical=\"center\"\n",
        "                )\n",
        "\n",
        "            # Pintar os status do cargo (Como só tem erro, tudo fica vermelho)\n",
        "            if col == 6:\n",
        "                cell.fill = error_fill\n",
        "\n",
        "    # Ajustar a largura das colunas automaticamente\n",
        "    for col in ws.columns:\n",
        "        max_len = max(len(str(cell.value or \"\")) for cell in col)\n",
        "        col_letter = get_column_letter(col[0].column)\n",
        "        ws.column_dimensions[col_letter].width = max(max_len + 3, 12)\n",
        "\n",
        "    # Congelar painel\n",
        "    ws.freeze_panes = \"A2\"\n",
        "\n",
        "\n",
        "with pd.ExcelWriter(nome_arquivo_saida, engine=\"openpyxl\") as writer:\n",
        "    df_apenas_erros.to_excel(writer, sheet_name=\"Apenas Erros\", index=False)\n",
        "    formatar_aba(writer.sheets[\"Apenas Erros\"], df_apenas_erros)\n",
        "\n",
        "print(f\"\\nProcesso concluído! Baixando {nome_arquivo_saida}...\")\n",
        "files.download(nome_arquivo_saida)"
      ],
